create or replace view SC_LOG.INT_TMS.V_TD_NA_SC_TMS_BID_APP_RATES(
	LANE_ASSOCIATION_KEY COMMENT 'Lane Association ID - Foreign Key from T_MD_GBL_SC_TMS_LANE_ASSOCIATION Table',
	ORIGIN_CITY_STATE COMMENT 'Origin Zone Code',
	DESTINATION_CITY_STATE COMMENT 'Destination Zone Code',
	LANE COMMENT 'Lane Concates The Origin And Destination Zone Code',
	EQUIPMENT_TYPE COMMENT 'Equipment Type',
	CARRIER_CODE COMMENT 'Carrier Code',
	MODE COMMENT 'Shipment Mode',
	AWARD_PCT COMMENT 'Award Percentage Based On The Tariff Code',
	AWARD_LOAD_COUNT COMMENT 'Awarded Load Count',
	SERVICE_CODE COMMENT 'Service Code',
	ORIGIN COMMENT 'origin',
	DESTINATION COMMENT 'destination',
	RATE_EFFECTIVE_DATE COMMENT 'Effective Date',
	RATE_EXPIRATION_DATE COMMENT 'Expiration Date',
	RATE_PER_MILE_AMOUNT COMMENT 'Rate Per Mile Amount',
	MINIMUM_CHARGE_AMOUNT COMMENT 'Minimum Charge Amount',
	CURRENT_RPM COMMENT 'Current Rate Per Mile',
	CHARGE_TYPE COMMENT 'charge type',
	ALL_IN_COST COMMENT 'All In Cost Is The Toal Cost Basis Charge Code',
	TARIFF_CODE COMMENT 'tariff code',
	TARIFF_ID COMMENT 'tariffid',
	FMIC COMMENT 'Fmic',
	AAO COMMENT 'Aao Charge Code',
	CURRENT_VOLUME COMMENT 'Count(Ld_Leg_Id) With Dates In Between Rate_Effective_Date And Rate_Expiration_Date',
	RANK_NUMBER COMMENT 'Rank Number'
) COMMENT='Bid Apps Rate view'
 as(
--Cte: Bid App Rates Rate Rank Base Filtering
WITH CTE_BAR_WITH_RANK AS (
--Cte: Bid App Rates Rate Base Filtering
WITH CTE_BAR AS (
SELECT 
UDMTLR.LANE_ASSOCIATION_KEY AS LANE_ASSOCIATION_KEY,
UDMTLR.ORIGIN_ZONE_CODE AS ORIGIN_CITY_STATE,
UDMTLR.SHIPMENT_MODE  AS SHIPMENT_MODE,
--Case: Destination City State Derivation
CASE WHEN UDMTLR.SHIPMENT_MODE = 'TEMP CONTROL' THEN UDMTLR.DESTINATION_ZONE_CODE||'TC'
ELSE UDMTLR.DESTINATION_ZONE_CODE END AS DESTINATION_CITY_STATE, 
concat (UDMTLR.ORIGIN_ZONE_CODE, '-', UDMTLR.DESTINATION_ZONE_CODE) AS LANE,
--Case: Equipment Type Derivation
CASE WHEN UDMTLR.SHIPMENT_MODE= 'INTERMODAL' THEN '53IM' 
WHEN UDMTLR.SHIPMENT_MODE= 'TEMP CONTROL' THEN '53TC' ELSE '53FT' END as EQUIPMENT_TYPE,
UDMTLR.CARRIER_CODE AS CARRIER_CODE,
--Case: Mode Derivation Based on Equipment
CASE WHEN EQUIPMENT = '53IM' THEN 'IM' WHEN EQUIPMENT = 'LTL' THEN 'LTL' ELSE 'TL' END AS MODE,
--Case: Award Percentage Derivation
CASE WHEN PCTC.TARIFF_CODE LIKE '%-OPT-%' THEN PCTC.MAX_PERCENTAGE_CONSTRAINT/100 ELSE NULL END AS AWARD_PCT,
UDMTLR.SERVICE_CODE AS SERVICE_CODE,
BAL.ORIGIN AS ORIGIN,
BAL.DESTINATION AS DESTINATION,
UDMTLR.RATE_EFFECTIVE_DATE AS RATE_EFFECTIVE_DATE,
UDMTLR.RATE_EXPIRATION_DATE  AS RATE_EXPIRATION_DATE,
UDMTLR.RATE_MINIMUM_CHARGE_AMOUNT AS MINIMUM_CHARGE_AMOUNT,
BAL.TOTAL_MILES AS TOTAL_MILES,
UDMTLR.CHARGE_CODE AS CHARGE_CODE,
--Case: Current Rate Per Mile Derivation
CASE WHEN BAL.TOTAL_MILES <> 0 THEN (UDMTLR.RATE_MINIMUM_CHARGE_AMOUNT / BAL.TOTAL_MILES) ELSE NULL END AS CURRENT_RPM,
--Case: Charge Type Derivation
CASE WHEN UDMTLR.CHARGE_CODE= 'NA_FLAT' THEN 'Flat Rate'  ELSE 'Rate Per Mile' END AS CHARGE_TYPE,
UDMTLR.TARIFF_CODE AS TARIFF_CODE,
UDMTLR.TARIFF_ID AS TARIFF_ID,
WG.TOTAL_MAX_QTY_CONSTRAINT AS TOTAL_MAX_QTY_CONSTRAINT,
QtyC.MAX_QUANTITY_CONSTRAINT,
udmtlr.BREAK_RATE_AMOUNT AS BREAK_RATE_AMOUNT,
FMIC,
AAO,
CURRENT_VOLUME
FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_LANE_RATE UDMTLR
LEFT JOIN (select * from SC_LOG.INT_TMS.V_TD_NA_SC_TMS_PERCENT_CONSTRAINT 
--Filter: Active Lanes Based On Current Date
WHERE LANE_EFFECTIVE_DATE < CURRENT_DATE AND LANE_EXPIRATION_DATE > CURRENT_DATE) PCTC
ON PCTC.LANE_DESCRIPTION=CONCAT (UDMTLR.ORIGIN_ZONE_CODE, '-', UDMTLR.DESTINATION_ZONE_CODE) 
AND UDMTLR.CARRIER_CODE = PCTC.CARRIER_CODE AND UDMTLR.SERVICE_CODE = PCTC.SERVICE_CODE AND UDMTLR.TARIFF_ID = PCTC.TARIFF_ID
LEFT JOIN SC_LOG.INT_TMS.V_TD_NA_SC_TMS_QUANTITY_CONSTRAINT QTYC
ON CONCAT(UDMTLR.ORIGIN_ZONE_CODE, '-', UDMTLR.DESTINATION_ZONE_CODE) = QTYC.LANE_DESCRIPTION
AND UDMTLR.SERVICE_CODE = QTYC.SERVICE_CODE
AND UDMTLR.TARIFF_ID = QTYC.TARIFF_ID
LEFT JOIN SC_LOG.INT_TMS.V_TD_NA_SC_TMS_WEEKLY_GROUP WG
ON CONCAT(UDMTLR.ORIGIN_ZONE_CODE, '-', UDMTLR.DESTINATION_ZONE_CODE) = WG.LANE_DESCRIPTION 
AND UDMTLR.SERVICE_CODE = WG.SERVICE_CODE
JOIN SC_LOG.INT_TMS.V_TD_NA_SC_TMS_BID_APP_LANES BAL
ON BAL.LANE_ASSOCIATION_KEY = UDMTLR.LANE_ASSOCIATION_KEY)
SELECT 
LANE_ASSOCIATION_KEY,
ORIGIN_CITY_STATE,
DESTINATION_CITY_STATE,
LANE,
EQUIPMENT_TYPE,
CARRIER_CODE,
MODE,
--Case: Award Percentage Derivation
CASE WHEN AWARD_PCT = 0 THEN NULL ELSE AWARD_PCT END AS AWARD_PCT,
--Case: Award Load Count Derivation
CASE WHEN AWARD_PCT IS NOT NULL AND TARIFF_ID IS NULL AND TARIFF_CODE LIKE '%-OPT-%' THEN NULL
WHEN Tariff_Code like '%-OPT-%' THEN  MAX_QUANTITY_CONSTRAINT * 52
ELSE NULL END AS AWARD_LOAD_COUNT,
SERVICE_CODE,
ORIGIN,
DESTINATION,
RATE_EFFECTIVE_DATE,
RATE_EXPIRATION_DATE,
--Case: Rate Per Mile Amount Derivation
CASE  WHEN CHARGE_TYPE = 'Flat Rate' THEN BREAK_RATE_AMOUNT
ELSE (BREAK_RATE_AMOUNT) - (CASE WHEN EQUIPMENT_TYPE = '53IM' THEN 0.312 ELSE 0 END)END AS RATE_PER_MILE_AMOUNT,
MINIMUM_CHARGE_AMOUNT,
CURRENT_RPM,
CHARGE_TYPE,
--Case: All In Cost Derivation
CASE  WHEN Charge_Code = 'Flat Rate' 
              THEN (RATE_PER_MILE_AMOUNT * TOTAL_MILES)
ELSE (RATE_PER_MILE_AMOUNT * TOTAL_MILES) + 
             (CASE  WHEN SHIPMENT_MODE= 'INTERMODAL' 
                              THEN 0.29 ELSE 0.55  END)
END AS ALL_IN_COST,
TARIFF_CODE,
TARIFF_ID,
FMIC,
Charge_Code AS AAO,
CURRENT_VOLUME
FROM CTE_BAR)
SELECT 
LANE_ASSOCIATION_KEY,
ORIGIN_CITY_STATE,
DESTINATION_CITY_STATE,
LANE,
EQUIPMENT_TYPE,
CARRIER_CODE,
MODE,
AWARD_PCT,
AWARD_LOAD_COUNT,
SERVICE_CODE,
ORIGIN,
DESTINATION,
RATE_EFFECTIVE_DATE,
RATE_EXPIRATION_DATE,
RATE_PER_MILE_AMOUNT,
MINIMUM_CHARGE_AMOUNT,
CURRENT_RPM,
CHARGE_TYPE,
ALL_IN_COST,
TARIFF_CODE,
TARIFF_ID,
FMIC,
AAO,
CURRENT_VOLUME,
DENSE_RANK() OVER(PARTITION BY origin_city_state, destination_city_state
ORDER BY RATE_PER_MILE_AMOUNT ASC, service_code DESC,  MINIMUM_CHARGE_AMOUNT ASC, CARRIER_CODE ASC) as RANK_NUMBER  
FROM CTE_BAR_WITH_RANK
--Filter: Effective Rate Date
WHERE RATE_EFFECTIVE_DATE >= '2026-03-15'
);
