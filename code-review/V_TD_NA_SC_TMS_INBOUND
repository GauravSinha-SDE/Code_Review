create or replace view SC_LOG.INT_TMS.V_TD_NA_SC_TMS_INBOUND(
	LOAD_LEG_KEY COMMENT 'Load Leg Key',
	LOAD_LEG_ID COMMENT 'Identifier For The Load Leg',
	CURRENT_OPERATIONAL_STATUS_ID COMMENT 'Current Operational Status Id',
	STATUS_SHORT_DESCRIPTION COMMENT 'Status Short Description',
	ORIGIN_SHIPPING_LOCATION_KEY COMMENT 'The Shipping Location Id For The First Pickup Stop For The Load.',
	FIRST_SHIPPING_LOCATION_CODE COMMENT 'The Shipping Location Code For The First Pickup Stop For The Load; Will Contain A Value When Stops Exist For The Load',
	ORIGIN_ADDRESS_KEY COMMENT 'The Address Key For The First Pickup Stop For The Load; Will Contain E Value When Stops Exist For The Load',
	FIRST_CITY_NAME COMMENT 'First City Name',
	FIRST_STATE_CODE COMMENT 'First State Code',
	CARRIER_KEY COMMENT 'Carrier ID  Foreign Key From T_MD_GBL_SC_TMS_CARRIER.CARRIER_KEY Table',
	MASTER_SERVICE_KEY COMMENT 'Service ID Foreign Key From T_MD_GBL_SC_TMS_SERVICE.MASTER_SERVICE_KEY Table',
	DISTANCE_IN_MILE_TOTAL COMMENT 'Mile Distance',
	END_DATE_TIME COMMENT 'End Date/Time',
	DESTINATION_SHIPPING_LOCATION_KEY COMMENT 'The Shipping Location Id For The Final Delivery Stop For The Load; Will Contain A Value When Stops Exist For The Load',
	LAST_SHIPPING_LOCATION_CODE COMMENT 'The Shipping Location Code For The Final Delivery Stop For The Load; Will Contain A Value When Stops Exist For The Load',
	SHIPPING_LOCATION_NAME COMMENT 'Shipping Location Name',
	DESTINATION_ADDRESS_KEY COMMENT 'The Address Key For The Last Stop For The Road.',
	LAST_CITY_NAME COMMENT 'Last City Name',
	LAST_STATE_CODE COMMENT 'Last State Code',
	LAST_POSTAL_CODE COMMENT 'Last Postal Code',
	CUSTOMER_HIERARCHY COMMENT 'Customer Hierarchy',
	TRAILER_EQUIPMENT_TYPE COMMENT 'Trailer Equipment Type',
	MAX_VOLUME COMMENT 'Max Volume',
	NUMBER_OF_STOP_TOTAL COMMENT 'Number Of Total Stop',
	LAST_COUNTRY_CODE COMMENT 'Last Country Code',
	TOT_SCLD_WGT COMMENT 'Total Scheduled Weight',
	START_DATE_TIME COMMENT 'Start Date Time',
	WEEK_NUM COMMENT 'Week Number',
	DAY_OF_WEEK COMMENT 'Day Of Week',
	END_DOW COMMENT 'End Dow',
	CC_SOURCE_SYSTEM COMMENT 'Source System',
	CC_TIMEZONE COMMENT 'Time Zone',
	LANE COMMENT 'Concat Of Origin Zone Code and Destination Zone Code',
	ACTUAL_CHARGE_AMOUNT COMMENT 'Actual Charge Amount',
	ACTUAL_LINEHAUL COMMENT 'Actual Linehaul'
) COMMENT='Handy Tools- Inbound View'
 as
/* CTE_SHIP_LOC Is Temporary Fix To Get Single Key Corresponding To Multiple Duplicate Shiping_location_code From Shipping_location Table.*/
WITH CTE_SHIP_LOC
AS
(
select  MAX(SHIPPING_LOCATION_KEY) as SHIPPING_LOCATION_KEY,SHIPPING_LOCATION_CODE,SHIPPING_LOCATION_NAME
from SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SHIPPING_LOCATION
group by SHIPPING_LOCATION_CODE,SHIPPING_LOCATION_NAME
),
CTE_ACT_LINEHAUL 
AS(
    SELECT 
    LOAD_LEG_ID, 
    SUM(PAYMENT_AMOUNT) AS PAYMENT_AMOUNT
    FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_COST
    WHERE  
    CHARGE_CODE IS NOT NULL
    AND UPPER(ACTUAL_CHARGE_TYPE) = 'ACTUAL_LINEHAUL'
    AND CHARGED_UNIT_RATE > 0 
    AND CHARGE_CODE NOT IN ('ZSPT') 
    GROUP BY LOAD_LEG_ID
)
SELECT DISTINCT LT.LOAD_LEG_KEY,
LT.LOAD_LEG_ID,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:CURRENT_OPERATIONAL_STATUS_ID,'""""') AS CURRENT_OPERATIONAL_STATUS_ID,
ST.STATUS_SHORT_DESCRIPTION,
LT.ORIGIN_SHIPPING_LOCATION_KEY,
LT.FIRST_SHIPPING_LOCATION_CODE,
LT.ORIGIN_ADDRESS_KEY,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:FIRST_CITY_NAME,'""""') AS FIRST_CITY_NAME,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:FIRST_STATE_CODE ,'""""') AS FIRST_STATE_CODE,
LT.CARRIER_KEY,
LT.MASTER_SERVICE_KEY,
LT.DISTANCE_IN_MILE_TOTAL*0.621379 AS DISTANCE_IN_MILE_TOTAL,--Conversion For Kilometer To Mile
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:END_DATE_TIME,'""""') AS END_DATE_TIME,
LT.DESTINATION_SHIPPING_LOCATION_KEY,
LT.LAST_SHIPPING_LOCATION_CODE,
LCD.SHIPPING_LOCATION_NAME,
LT.DESTINATION_ADDRESS_KEY,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_CITY_NAME, '""""') AS LAST_CITY_NAME,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_STATE_CODE ,'""""') AS LAST_STATE_CODE,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_POSTAL_CODE ,'""""') AS LAST_POSTAL_CODE,
Coalesce (CH.CUSTOMER_PARENT,TRIM(LT.EXTENDED_ATTRIBUTES_TMS:DESTINATION_PLANT,'""""'),TRIM(LT.EXTENDED_ATTRIBUTES_TMS:ORIGIN_PLANT,'""""')) AS CUSTOMER_HIERARCHY,
LT.TRAILER_EQUIPMENT_TYPE,
LT.MAX_VOLUME*35.3146666751 AS MAX_VOLUME,--Conversion For Cubic Meter To Cubic Feet
LT.NUMBER_OF_STOP_TOTAL,
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_COUNTRY_CODE,'""""') AS LAST_COUNTRY_CODE ,
LT.SCALED_WEIGHT_TOTAL*2.20462261307789 AS TOT_SCLD_WGT,--Conversion For Kilogram To Pound
TRIM(LT.EXTENDED_ATTRIBUTES_TMS:START_DATE_TIME,'""""') AS START_DATE_TIME,
WEEK(TO_DATE(TRIM(LT.EXTENDED_ATTRIBUTES_TMS:START_DATE_TIME,'""""'))) AS WEEK_NUM,
UPPER(DAYNAME(TO_DATE(TRIM(LT.EXTENDED_ATTRIBUTES_TMS:START_DATE_TIME,'""""')))) AS DAY_OF_WEEK,
UPPER(DAYNAME(TO_DATE(TRIM(LT.EXTENDED_ATTRIBUTES_TMS:END_DATE_TIME,'""""')))) AS END_DOW,
'BY' AS CC_SOURCE_SYSTEM,
'UTC' AS CC_TIMEZONE,
CONCAT(OZC.ZONE_CODE,'-',DZC.ZONE_CODE) AS LANE,
LT.TENDER_RESPONSE_OVERRIDE_AMOUNT AS ACTUAL_CHARGE_AMOUNT,
COALESCE(LC.PAYMENT_AMOUNT,LT.TENDER_RESPONSE_OVERRIDE_AMOUNT) AS ACTUAL_LINEHAUL, 
FROM (SELECT DISTINCT LOAD_LEG_KEY FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_DETAIL) LD
INNER JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT LT
ON LD.LOAD_LEG_KEY = LT.LOAD_LEG_KEY
INNER JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_STATUS ST
ON LT.EXTENDED_ATTRIBUTES_TMS:CURRENT_OPERATIONAL_STATUS_ID = ST.STATUS_ID
INNER JOIN CTE_SHIP_LOC LCD
ON LCD.SHIPPING_LOCATION_KEY = LT.DESTINATION_SHIPPING_LOCATION_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_DIVISION DI
ON LT.DIVISION_KEY = DI.DIVISION_KEY
LEFT JOIN SC_LOG.INT_TMS.V_MD_NA_SC_TMS_CUSTOMER_HIERARCHY CH
ON CH.CUSTOMER_CODE = Coalesce (TRIM(LT.EXTENDED_ATTRIBUTES_TMS:DESTINATION_PLANT,'""""'),TRIM(LT.EXTENDED_ATTRIBUTES_TMS:ORIGIN_PLANT,'""""'))
LEFT JOIN CTE_ACT_LINEHAUL LC
ON LC.LOAD_LEG_ID = LT.LOAD_LEG_ID
LEFT JOIN SC_MD.INT_SC_MD.V_MD_NA_SC_TMS_ZONE OZC
ON CONCAT(LT.EXTENDED_ATTRIBUTES_TMS:FIRST_CITY_NAME, ', ', LT.EXTENDED_ATTRIBUTES_TMS:FIRST_STATE_CODE) = OZC.ZN_DESC AND OZC.ZONE_TYPE='ORIGIN' /*Added For DB11: Inbound & Outbound*/
LEFT JOIN SC_MD.INT_SC_MD.V_MD_NA_SC_TMS_ZONE DZC
ON CONCAT(LT.EXTENDED_ATTRIBUTES_TMS:LAST_CITY_NAME, ', ', LT.EXTENDED_ATTRIBUTES_TMS:LAST_STATE_CODE) = DZC.ZN_DESC
AND LEFT(LT.EXTENDED_ATTRIBUTES_TMS:LAST_POSTAL_CODE, 5) = DZC.POSTAL_CODE AND DZC.ZONE_TYPE='DEST'
WHERE DI.DIVISION_CODE = 'KCNA' /*To Filter Data For KCNA Load_leg_ids*/
AND LT.TRAILER_EQUIPMENT_TYPE NOT IN ('LTL','PKG') /*To Filter Data For Selected Equipment Types*/
AND TRIM(LT.EXTENDED_ATTRIBUTES_TMS:FIRST_COUNTRY_CODE,'""""') IN ('USA','CAN') /*Condition For Inbound*/
AND TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_COUNTRY_CODE,'""""') IN ('USA','CAN') /*Condition For Inbound*/
AND LT.LAST_SHIPPING_LOCATION_CODE LIKE ('2%') /*Condition For Inbound*/
/*Below Code For Incremantal Data Load*/
AND (CONVERT_TIMEZONE('America/Los_Angeles','UTC',LT.CC_UPDATED_DATETIMESTAMP) > COALESCE((SELECT DATEADD(HOUR, -2,LAST_SUCCESSFUL_LOAD_DATETIME) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2_IMP WHERE TARGET_TABLE_ID=(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_TMS.T_TD_GBL_SC_TMS_INBOUND')
AND SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2_IMP WHERE SOURCE_NAME='BY_TMS')
AND SOURCE_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_TMS.V_TD_NA_SC_TMS_INBOUND')), '1901-01-01'));
