create or replace view SC_LOG.INT_UDM_TMS.V_TD_GBL_SC_TMS_LOAD_TRANSPORT_LANE_RATE(
	TRANSPORT_LANE_RATE_KEY COMMENT 'PK For The Table Transport Lane Rate Made From (Lane_Assc_Id,Tff_id,Rate_Id,Efct_dt,Brk_Amt_Dlr)',
	LANE_ASSOCIATION_KEY COMMENT 'SK for Lane Asociation Table',
	CARRIER_KEY COMMENT 'Carrier ID - Foreign Key From T_MD_GBL_SC_TMS_CARRIER.CARRIER_KEY Table',
	BASE_DIVISION_KEY COMMENT 'Division - Foreign Key From T_MD_GBL_SC_TMS_DIVISION.DIVISION_KEY Table',
	TARIFF_KEY COMMENT 'Tariff Number - Foreign Key From T_MD_GBL_SC_TMS_TARIFF.TARIFF_KEY Table',
	RATE_CODE_TARIFF_KEY COMMENT 'Rate Code Tariff Number- Tariff Number - Foreign Key From T_MD_GBL_SC_TMS_TARIFF.TARIFF_KEY Table',
	TARIFF_CODE COMMENT 'Tariff ID - Tariff Number - Foreign Key From T_MD_GBL_SC_TMS_TARIFF.TFF_CD Table',
	RANGE_RATE_ID COMMENT 'Range Rate ID - Foreign Key From T_MD_GBL_SC_TMS_RANGE_RATE.RNG_RATE_ID Table',
	RATE_KEY COMMENT 'Rate ID - Foreign Key From T_MD_GBL_SC_TMS_RATE.RATE_ID Table',
	RATE_CODE COMMENT 'Rate Code',
	CHARGE_CODE COMMENT 'Charge ID',
	BREAK_RATE_AMOUNT COMMENT 'Rate',
	BASE_CHARGE_AMOUNT COMMENT 'Base Charge',
	CHARGE_ID COMMENT 'Tariff Charge ID',
	CURRENCY_CODE COMMENT 'Currency Code',
	CURRENCY_TYPE COMMENT 'Rating Currency',
	DESTINATION_ZONE_CODE COMMENT 'Destination Zone ID',
	RATE_EFFECTIVE_DATE COMMENT 'Effective Date',
	RATE_EXPIRATION_DATE COMMENT 'Expiration Date',
	RATE_MINIMUM_CHARGE_AMOUNT COMMENT 'Minimum Charge',
	ORIGIN_ZONE_CODE COMMENT 'Origin Zone ID',
	SERVICE_CODE COMMENT 'Service ID',
	SHIPMENT_MODE COMMENT 'Classification Of Shipment Based On Service Code And Charge Code Into Intermodal, Truck Etc',
	TARIFF_ID COMMENT 'Tariff Id',
	ORIGIN_COUNTRY_CODE COMMENT 'Origin Country Code',
	DESTINATION_COUNTRY_CODE COMMENT 'Destination Country Code',
	FIRST_POSTAL_CODE COMMENT 'First Postal Code - Most Frequently Used FRST_PSTL_CD  Basis The Count Of Load_Leg_Id In The Last 1 Year',
	ORIGIN_ZONE_DESCRIPTION COMMENT 'Origin Zone / City',
	DESTINATION_ZONE_DESCRIPTION COMMENT 'Destination Zone / City',
	LANE_STATUS_DESCRIPTION COMMENT 'Lane Status Description',
	TOTAL_MILES COMMENT 'Total Miles',
	TOTAL_KILOMETERS COMMENT 'Total Kilometers',
	CC_SOURCE_SYSTEM COMMENT 'Source System',
	CC_CREATED_DATETIMESTAMP COMMENT 'Record Created Time Stamp',
	CC_UPDATED_DATETIMESTAMP COMMENT 'Record Updated Time Stamp',
	CC_TIMEZONE COMMENT 'Time Zone',
	LANE_ASSOCIATION_ID COMMENT 'Lane Association Id',
	RATE_ID_FROM_RANGE COMMENT 'Rate Id From Range Rate Table',
	TARIFF_STATUS_DESCRIPTION COMMENT 'Tariff Service Description',
	MASTER_SERVICE_KEY COMMENT 'Master Service Key From Service table',
	CARRIER_CODE COMMENT 'Carrier Code From Carrier Table'
) COMMENT='This Table Outlines The Costs, Rates, Or Pricing Associated With Transporting Goods Along Specific Lanes(Like A Rate Card). Each Entry In The Table Corresponds To A Unique Combination Of An Origin, Destination, And Other Relevant Parameters, Providing A Clear Breakdown Of The Associated Transportation Costs.Nhas Context Menu'
 as
(
/*Cte: Config Lookup Table For Shipment Mode Mapping*/

WITH CTE_CNFG_TBL AS
(
    SELECT COLUMN_NAME,
           CODE_VALUE,
           CODE_DESCRIPTION,
           GROUP_DESCRIPTION 
    FROM TMS.STAGING.T_GBL_BY_CONFIG_LKP
/* Filter: Shipment Mode Mapping */
    WHERE UPPER(COLUMN_NAME) IN ('SRVC_DESC','CHRG_CD') 
      AND UPPER(GROUP_DESCRIPTION) = 'SHIPMENT_MODE'
),
/*Cte: Get The Lane Detail Per Load Leg Wise*/
TRANS_LD_SEL
AS
(
SELECT LT.LOAD_LEG_ID,TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LANE_ASSOCIATION_ID,'""""') AS LANE_ASSOCIATION_ID, --2,084,613 --17,784
        TRIM(LT.EXTENDED_ATTRIBUTES_TMS:ORIGIN_POSTAL_CODE,'""""') AS ORIGIN_POSTAL_CODE,
        LT.SHIPPED_DATE,
        LT.DISTANCE_IN_MILE_TOTAL AS DISTANCE_IN_MILE_TOTAL
FROM  SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT LT
/* Filter: Valid Lane Association Id */
WHERE TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LANE_ASSOCIATION_ID,'""""')  IS NOT NULL
),
/*Cte: Calculate First Postal Code - Most Frequently Used Postal Code Basis The Count Of Load_Leg_Id In The Last 1 Year*/
FST_POSTAL_CD
AS
(
SELECT LANE_ASSOCIATION_ID,ORIGIN_POSTAL_CODE
FROM (
        SELECT LANE_ASSOCIATION_ID, 
                --,COUNT(LT.LOAD_LEG_ID)
                ORIGIN_POSTAL_CODE,
                ROW_NUMBER() OVER (PARTITION BY LANE_ASSOCIATION_ID ORDER BY COUNT(LOAD_LEG_ID) DESC) AS RNK
        FROM  TRANS_LD_SEL
        WHERE  YEAR(SHIPPED_DATE)>= YEAR(CURRENT_TIMESTAMP())-1
        GROUP BY LANE_ASSOCIATION_ID,ORIGIN_POSTAL_CODE
    ) WHERE RNK =1
),
/*Cte: Calculate The Average Of Distance In Total Miles And Total Kilometers*/
TRANS_MILES_SEL
AS
(
SELECT 
	LANE_ASSOCIATION_ID,AVG(DISTANCE_IN_MILE_TOTAL) AS TOTAL_KILOMETERS, 
	AVG(DISTANCE_IN_MILE_TOTAL * 0.621379) AS TOTAL_MILES --Conversion To Mile
FROM  TRANS_LD_SEL
GROUP BY LANE_ASSOCIATION_ID
) 
/******* FINAL Select Statement *********/
Select distinct
HASH(LA.LANE_ASSC_ID,T.TFF_CD,R.RATE_ID,R.EFCT_DT,RR.RNG_RATE_ID,'BY') AS TRANSPORT_LANE_RATE_KEY,
HASH(LA.LANE_ASSC_ID,'BY') AS LANE_ASSOCIATION_KEY,
CAR.CARRIER_KEY  AS CARRIER_KEY,
DIV.DIVISION_KEY AS BASE_DIVISION_KEY,
TFF.TARIFF_KEY AS TARIFF_KEY,
TAR.TARIFF_KEY AS RATE_CODE_TARIFF_KEY,
T.TFF_CD AS TARIFF_CODE,
RR.RNG_RATE_ID AS RANGE_RATE_ID,
R.RATE_ID AS RATE_KEY,
R.RATE_CD AS RATE_CODE, 
R.CHRG_CD AS CHARGE_CODE,
RR.BRK_AMT_DLR AS BREAK_RATE_AMOUNT,
R.BS_CHRG_DLR AS BASE_CHARGE_AMOUNT,
R.CHRG_ID AS CHARGE_ID,
C.CNCY_CD AS CURRENCY_CODE,
T.CNCY_TYP AS CURRENCY_TYPE,
LA.DEST_ZN_CD AS DESTINATION_ZONE_CODE,
R.EFCT_DT AS RATE_EFFECTIVE_DATE,
R.EXPD_DT AS RATE_EXPIRATION_DATE,
R.MIN_CHRG_DLR AS RATE_MINIMUM_CHARGE_AMOUNT,
LA.ORIG_ZN_CD AS ORIGIN_ZONE_CODE,
LA.SRVC_CD AS SERVICE_CODE,
/* Case: Shipment Mode Derivation Logic */
CASE WHEN CN.CODE_DESCRIPTION is not null THEN CN.CODE_DESCRIPTION
     WHEN CN1.CODE_DESCRIPTION is not null THEN CN1.CODE_DESCRIPTION
     WHEN ((MST.SRVC_DESC = '' OR MST.SRVC_DESC is null) AND (R.CHRG_CD ='' OR R.CHRG_CD is null)) THEN null
     ELSE 'TRUCK' END AS SHIPMENT_MODE, /*Calculation As Per Logic Provided In BRD*/
/*START: Attributes Added For BAL*/     
TFF.TARIFF_ID AS TARIFF_ID,
LA.ORIG_CTRY_CD AS ORIGIN_COUNTRY_CODE,
LA.DEST_CTRY_CD AS DESTINATION_COUNTRY_CODE,
FST.ORIGIN_POSTAL_CODE AS FIRST_POSTAL_CODE,
/* Case: Origin Zone Description Cleanup */
CASE WHEN ZN.ZN_DESC LIKE 'KC in %' THEN REPLACE(ZN.ZN_DESC,'KC in ','') 
     WHEN ZN.ZN_DESC LIKE '% KCP' THEN REPLACE(ZN.ZN_DESC,' KCP','')
     WHEN ZN.ZN_DESC LIKE '% SKIN CARE' THEN REPLACE(ZN.ZN_DESC,' SKIN CARE','')
     ELSE ZN.ZN_DESC END AS ORIGIN_ZONE_DESCRIPTION, /*Calculation As Per Logic Provided In BRD*/
/* Case: Destination Zone Description Cleanup */
CASE WHEN ZND.ZN_DESC LIKE 'KC in %' THEN REPLACE(ZND.ZN_DESC,'KC in ','') 
     WHEN ZND.ZN_DESC LIKE '% KCP' THEN REPLACE(ZND.ZN_DESC,' KCP','')
     WHEN ZND.ZN_DESC LIKE '% SKIN CARE' THEN REPLACE(ZND.ZN_DESC,' SKIN CARE','')
     ELSE ZND.ZN_DESC END AS DESTINATION_ZONE_DESCRIPTION, /*Calculation as per logic provided in BRD*/
DLK.BY_CODE_VALUE AS LANE_STATUS_DESCRIPTION,
DIS.TOTAL_MILES AS TOTAL_MILES,
DIS.TOTAL_KILOMETERS AS TOTAL_KILOMETERS,
/*END: Attributes Added For BAL*/ 
'BY' AS CC_SOURCE_SYSTEM,
CURRENT_TIMESTAMP() AS CC_CREATED_DATETIMESTAMP,
CURRENT_TIMESTAMP() AS CC_UPDATED_DATETIMESTAMP,
'UTC' AS CC_TIMEZONE,
/*START: Attributes Added For Quantity Constraints View*/
LA.LANE_ASSC_ID AS LANE_ASSOCIATION_ID,
RR.RATE_ID AS RATE_ID_FROM_RANGE,
TFF.TARIFF_STATUS_DESCRIPTION AS TARIFF_STATUS_DESCRIPTION,
HASH(MST.SRVC_CD,'BY') AS MASTER_SERVICE_KEY,
CAR.CARRIER_ID AS CARRIER_CODE
/*END: Attributes Added For Quantity Constraints View*/
FROM TMS.STAGING.TFF_T T
LEFT JOIN TMS.STAGING.BY_LANE_ASSC_T LA ON LA.TFF_ID = T.TFF_ID
LEFT JOIN TMS.STAGING.BY_RATE_T R ON LA.TFF_ID = R.TFF_ID AND LA.RATE_CD = R.RATE_CD
LEFT JOIN TMS.STAGING.RNG_RATE_T RR ON RR.RATE_ID = R.RATE_ID
LEFT JOIN TMS.STAGING.MSTR_SRVC_T MST ON LA.SRVC_CD = MST.SRVC_CD
LEFT JOIN TMS.STAGING.CNCY_T C ON C.CNCY_TYP = t.CNCY_TYP 
LEFT JOIN CTE_CNFG_TBL CN  ON UPPER(MST.SRVC_DESC) LIKE ANY CN.CODE_VALUE AND UPPER(cn.COLUMN_NAME) = 'SRVC_DESC'
LEFT JOIN CTE_CNFG_TBL CN1  ON UPPER(R.CHRG_CD) LIKE ANY CN1.CODE_VALUE AND UPPER(cn1.COLUMN_NAME) = 'CHRG_CD'
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_CARRIER CAR on  T.CARR_CD = CAR.CARRIER_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_DIVISION DIV on LA.BASE_DIV_CD= DIV.DIVISION_CODE
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_TARIFF TFF on LA.TFF_ID = TFF.TARIFF_ID 
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_TARIFF TAR on LA.RATECD_TFF_ID = TAR.TARIFF_ID
LEFT JOIN TMS.STAGING.ZN_T ZN ON ZN.ZN_CD = LA.ORIG_ZN_CD AND UPPER(ZN.CTRY_CD) = 'USA' --Filter: USA Country Restriction
LEFT JOIN TMS.STAGING.ZN_T ZND ON ZND.ZN_CD = LA.DEST_ZN_CD AND UPPER(ZND.CTRY_CD) = 'USA' --Filter: USA Country Restriction
LEFT JOIN TMS.STAGING.T_GBL_BY_DOMAIN_LKP DLK ON DLK.BY_CODE = LA.STAT_ENU AND DLK.DOMAIN_COLUMN_NAME='STAT_ENU' and DLK.DOMAIN_TYPE_ID =26
LEFT JOIN FST_POSTAL_CD FST ON FST.LANE_ASSOCIATION_ID = LA.LANE_ASSC_ID
LEFT JOIN TRANS_MILES_SEL DIS ON DIS.LANE_ASSOCIATION_ID = LA.LANE_ASSC_ID
/*WHERE Clause For Fetching New/Updated Records From Src Table After Previous Successful Load*/
WHERE T.CC_UPDATED_DATETIMESTAMP > IFNULL( (SELECT DATEADD(hour, -2,LAST_SUCCESFULL_LOAD_DATETIME) AS LAST_SUCCESFULL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG 
WHERE SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE WHERE SOURCE_NAME='BY_TMS') 
AND TARGET_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_LANE_RATE')
AND SOURCE_TABLE_ID =(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.V_TD_GBL_SC_TMS_LOAD_TRANSPORT_LANE_RATE')) ,'1901-01-01')
);
