(
/*To make same datatype and precision for all Domain (*_ENUs) attributes*/
WITH CTE_CNVT_DT
AS
(select LD_LEG_ID, TO_NUMBER(PLNG_STAT_ENU) AS PLNG_STAT_ENU,
--TO_NUMBER(CUR_OPTLSTAT_ID) AS CUR_OPTLSTAT_ID, /*Now fetching form master status table*/
TO_NUMBER(UMSRSYS_ENU) AS UMSRSYS_ENU ,
TO_NUMBER(UMSRWGT_ENU) AS UMSRWGT_ENU,
TO_NUMBER(UMSRLEN_ENU) AS UMSRLEN_ENU,
TO_NUMBER(UMSRDIST_ENU) AS UMSRDIST_ENU,
TO_NUMBER(FRST_SHPGPNT_ENU) AS FRST_SHPGPNT_ENU,
TO_NUMBER(LAST_SHPGPNT_ENU) AS LAST_SHPGPNT_ENU,
TO_NUMBER(AUTO_TDR_STAT_ENU) AS AUTO_TDR_STAT_ENU,
TO_NUMBER(SUS_FUNC_ENU) AS SUS_FUNC_ENU,
TO_NUMBER(LD_SRC_ENU) AS LD_SRC_ENU
from TMS.STAGING.BY_LD_LEG_T
WHERE CC_UPDATED_DATETIMESTAMP > IFNULL( (SELECT DATEADD(hour, -2,CONVERT_TIMEZONE('UTC',LAST_SUCCESSFUL_LOAD_DATETIME)) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2_IMP
WHERE SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2_IMP WHERE SOURCE_NAME='BY_TMS') 
AND TARGET_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT')
AND SOURCE_TABLE_ID =(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.V_TD_GBL_SC_TMS_LOAD_TRANSPORT')) ,'1901-01-01')
),
/*To unpivot *_ENU attributes of src table and get their BY_CODE_VALUEs from Domain lkp table */
CTE_LD_TRAN_LKP
AS
(
SELECT  d.BY_CODE_VALUE, p.*
from ( 
    Select 
    LD_LEG_ID,
    DOMAIN_COL_NM,
    CODE_VAL
    FROM CTE_CNVT_DT 
    UNPIVOT (
            CODE_VAL FOR DOMAIN_COL_NM IN         (PLNG_STAT_ENU,UMSRSYS_ENU,UMSRWGT_ENU,UMSRLEN_ENU,UMSRDIST_ENU,FRST_SHPGPNT_ENU,LAST_SHPGPNT_ENU,AUTO_TDR_STAT_ENU,SUS_FUNC_ENU,LD_SRC_ENU )
          ) 
      ) p 
  LEFT JOIN TMS.STAGING.T_GBL_BY_DOMAIN_LKP d
  on d.domain_column_name = p.DOMAIN_COL_NM 
  and d.by_code = p.CODE_VAL 
where concat(domain_column_name, '|', domain_type_id ) in ( 'PLNG_STAT_ENU|430','UMSRSYS_ENU|47','UMSRWGT_ENU|48','UMSRLEN_ENU|46','UMSRDIST_ENU|262','FRST_SHPGPNT_ENU|68','LAST_SHPGPNT_ENU|68','AUTO_TDR_STAT_ENU|249','SUS_FUNC_ENU|149','LD_SRC_ENU|410'
  ) 
),
/*To aggregate BY_CODE_VALUEs and fetch not null code value corresponding to their domain name.*/
CTE_DOMAIN_VAL 
AS(
Select LD_LEG_ID,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='PLNG_STAT_ENU' THEN CL.BY_CODE_VALUE END) AS CURRENT_PLAN_STATUS_ENUM_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='UMSRSYS_ENU' THEN CL.BY_CODE_VALUE END) AS UOM_MEASURE_TYPE_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='UMSRWGT_ENU' THEN CL.BY_CODE_VALUE END) AS UOM_WEIGHT_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='UMSRLEN_ENU' THEN CL.BY_CODE_VALUE END) AS UOM_LENGTH_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='UMSRDIST_ENU' THEN CL.BY_CODE_VALUE END) AS UOM_DISTANCE_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='FRST_SHPGPNT_ENU' THEN CL.BY_CODE_VALUE END) AS ORIGIN_SHIPPING_POINT_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='LAST_SHPGPNT_ENU' THEN CL.BY_CODE_VALUE END) AS DESTINATION_SHIPPING_POINT_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='AUTO_TDR_STAT_ENU' THEN CL.BY_CODE_VALUE END) AS AUTOMATIC_TENDER_STATUS_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='SUS_FUNC_ENU' THEN CL.BY_CODE_VALUE END) AS SUSPENDED_REASON_DESCRIPTION,
MAX(CASE WHEN CL.DOMAIN_COL_NM ='LD_SRC_ENU' THEN CL.BY_CODE_VALUE END) AS LOAD_SOURCE_DESCRIPTION
from CTE_LD_TRAN_LKP CL
group by LD_LEG_ID
), 
/* CTE_SHIP_LOC is Temporary fix to get single key corresponding to multiple duplicate shiping_location_code from shipping_location table.*/
CTE_SHIP_LOC
AS
(
select  MAX(SHIPPING_LOCATION_KEY) as SHIPPING_LOCATION_KEY,SHIPPING_LOCATION_CODE
from SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SHIPPING_LOCATION
group by SHIPPING_LOCATION_CODE
),
/* CTE_TRN_STOP is Temporary fix to get single key corresponding to multiple duplicate STOP_IDs from STOP table.*/
CTE_TRN_STOP
AS
(
select max(STOP_KEY) as STOP_KEY, STOP_ID 
from SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_STOP
group by STOP_ID
),
/*CTE CTE_AUDT_STOP is for to get STOP_APT_TO_DTT from auidt_stop_t table corresponding to ld_leg_id*/
CTE_AUDT_STOP
AS
(
SELECT LD_LEG_ID,APPOINTMENT_TO_TIME 
FROM (
        SELECT  DV.LD_LEG_ID,
                STOP_APT_FRM_DTT AS APPOINTMENT_FROM_TIME,
                STOP_APT_TO_DTT AS APPOINTMENT_TO_TIME,
                AUDT_SYS_DTT AS APPOINTMENT_CHANGE_TIME,
                STOP_APT_CUR_STAT_DESC AS LOAD_STATUS,
                AUDT_SEC_CD AS REASON_CODE,
                ROW_NUMBER() OVER (PARTITION BY AU.LD_LEG_ID ORDER BY AUDT_SYS_DTT ASC) AS Rank
        FROM TMS.STAGING.AUDT_STOP_T AU
        INNER JOIN CTE_DOMAIN_VAL DV ON AU.LD_LEG_ID = DV.LD_LEG_ID
        WHERE STOP_SEQ_NUM = 1 AND YEAR(AUDT_SYS_DTT) >=(YEAR(SYSDATE()) - 1)
    ) WHERE RANK = 1
)
