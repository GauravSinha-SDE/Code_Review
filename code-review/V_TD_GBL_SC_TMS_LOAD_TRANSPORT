CURRENT_TIMESTAMP() AS CC_UPDATED_DATETIMESTAMP,
'UTC' AS CC_TIMEZONE,
DAT.CORP1_ID AS LOAD_AT_CORPORATE_ID_1, /*Added as per Service scorecard BRD doc*/
CN.CORP1_ID AS CONSIGNEE_CORPORATE_ID_1, /*Added as per Service scorecard BRD doc*/
DAT.NAME AS LOAD_AT_NAME, /*Added as per Service scorecard BRD doc*/
LLT.FRST_SHPG_LOC_CD AS FIRST_SHIPPING_LOCATION_CODE, /*Added as per Service scorecard BRD doc*/
LLT.LAST_SHPG_LOC_CD AS LAST_SHIPPING_LOCATION_CODE, /*Added as per Service scorecard BRD doc*/
DAT.CORP2_ID AS LOAD_AT_CORPORATE_ID_2, /*Added as per Service scorecard BRD doc as extended*/
MDC.SUPPLIERTYPE AS SUPPLIER_TYPE, /*Added as per Service scorecard BRD doc as extended*/
IFF(MDC.SUPPLIERTYPE = 'Broker', 'Y', 'N') AS BROKER_FLAG, /*Added as per Service scorecard BRD doc as extended*/
TTT.LIVE_LOAD_FLAG AS LIVELOAD, /*Added as per Service scorecard BRD doc as extended*/
IFF(MDC.SUPPLIERTYPE = 'Dedicated', 'Y', 'N') AS DEDICATED_CARRIER_FLAG, /*Added as per Service scorecard BRD doc as extended*/
LLT.RFRC_NUM27 AS RFRC_NUM27, /*Added as per Service scorecard BRD doc as extended*/
LLT.LAST_SEC_CD AS LAST_EVENT_REASON_CODE, /*Added as DB7:EDIAA BRD doc as extended*/
LLT.FRST_PSTL_CD AS ORIGIN_POSTAL_CODE, /*Added as per DB4:BAL BRD doc as extended*/
LLT.LAST_PSTL_CD AS DESTINATION_POSTTAL_CODE, /*Added as per DB4:BAL BRD doc as extended*/
LLT.LANE_ASSC_ID AS LANE_ASSOCIATION_ID, /*Added as per DB4:BAL BRD doc as extended*/

-- Origin: Derived From First Shipping Location Code Using Prefix Rules (V=Vendor, 1/2=DC); Stable K-C Mapping
CASE 
    WHEN SUBSTR(LLT.FRST_SHPG_LOC_CD, 1, 1) = 'V' THEN SUBSTR(LLT.FRST_SHPG_LOC_CD, 1, 9)
    WHEN SUBSTR(LLT.FRST_SHPG_LOC_CD, 1, 1) IN ('1', '2') THEN SUBSTR(LLT.FRST_SHPG_LOC_CD, 1, 4) || ' - ' || LLT.FRST_CTY_NAME
    ELSE 'UNKNOWN' 
  END AS ORIGIN_PLANT, /*Added as per DB4:BAL BRD doc as extended*/
  
-- Destination: Derived From Last Shipping Location Code Using Prefix Rules (5=Customer, 1/2=DC); Stable K-C Mapping
CASE 
  WHEN SUBSTRING(LLT.LAST_SHPG_LOC_CD, 1, 1) = '5' THEN SUBSTRING(LLT.LAST_SHPG_LOC_CD, 1, 8)
  WHEN SUBSTRING(LLT.LAST_SHPG_LOC_CD, 1, 1) IN ('1', '2') THEN SUBSTRING(LLT.LAST_SHPG_LOC_CD, 1, 4) || ' - ' || LLT.LAST_CTY_NAME
  ELSE 'UNKNOWN' 
END AS DESTINATION_PLANT, /*Added as per DB4:BAL BRD doc as extended*/

CASE 
  WHEN LLT.EQMT_TYP = '53IM' AND ((LLT.FIXD_ITNR_DIST * 0.6213) < 600) AND LLT.SRVC_CD <>'FECD' THEN 'TRUCK'
  WHEN LLT.EQMT_TYP = '53IM' THEN 'INTERMODAL'
  WHEN LLT.EQMT_TYP = 'LTL'  THEN 'LTL'
  ELSE NULL
END AS SHIPMENT_MODE, /*Added as per DB1:SSC BRD doc as extended*/

LLT.FRST_CTY_NAME AS FIRST_CITY_NAME, /*Added as per DB1:SSC BRD doc as extended*/
LLT.FRST_STA_CD AS FIRST_STATE_CODE, /*Added as per DB1:SSC BRD doc as extended*/
LLT.FRST_PSTL_CD AS FIRST_POSTAL_CODE, /*Added as per DB1:SSC BRD doc as extended*/
LLT.FRST_CTRY_CD AS FIRST_COUNTRY_CODE, /*Added as per DB1:SSC BRD doc as extended*/
LLT.LAST_CTY_NAME AS LAST_CITY_NAME, /*Added as per DB1:SSC BRD doc as extended*/
LLT.LAST_STA_CD AS LAST_STATE_CODE, /*Added as per DB1:SSC BRD doc as extended*/
LLT.LAST_PSTL_CD AS LAST_POSTAL_CODE, /*Added as per DB1:SSC BRD  doc as extended*/
LLT.LAST_CTRY_CD AS LAST_COUNTRY_CODE, /*Added as per DB1:SSC BRD  doc as extended*/
AUS.APPOINTMENT_TO_TIME AS ORIGINAL_PICKUP_TO_DATE_TIME, /*Added as per DB1:SSC BRD doc*/
LA.DESTINATION_ZONE_CODE AS DESTINATION_ZONE_CODE, /*Added as per DB11: Inbound & Outbound BRD doc*/
CASE WHEN CONCAT(UPPER(TO_CHAR(LLT.FRST_CTY_NAME)),', ',UPPER(TO_CHAR(LLT.FRST_STA_CD))) IN ('BEECH ISLAND, SC','GRANITEVILLE, SC', 'AUGUSTA, GA') 
THEN 'BILCAMP'
WHEN UPPER(LLT.FRST_CTY_NAME) IN ('MENASHA', 'LITTLE CHUTE', 'KAUKAUNA', 'APPLETON') AND UPPER(LLT.FRST_STA_CD) = 'WI' 
THEN 'WIFOXVAL'
WHEN LEFT(UPPER(LA.ORIGIN_ZONE_CODE),8) = 'KCILROME' THEN 'ILROMEOV'
WHEN UPPER(LLT.FRST_CTY_NAME) IN ('GREEN BAY', 'DE PERE', 'HOBART') AND UPPER(LLT.FRST_STA_CD) = 'WI' 
THEN 'WIGBCAMP'
WHEN UPPER(LLT.FRST_CTY_NAME) IN ('MILWAUKEE','CUDAHY','OAK CREEK', 'WEST ALLIS') AND UPPER(LLT.FRST_STA_CD) = 'WI' 
THEN 'WIMILCAM' ELSE LA.ORIGIN_ZONE_CODE END AS ORIGIN_ZONE_CODE, /*Added as per DB11: Inbound & Outbound BRD doc*/
LLT.RFRC_NUM23 AS RFRC_NUM23,
LLT.RFRC_NUM2 AS RFRC_NUM2,
LLT.RFRC_NUM14 AS RFRC_NUM14

FROM TMS.STAGING.BY_LD_LEG_T LLT 
LEFT JOIN CTE_DOMAIN_VAL DV ON DV.LD_LEG_ID = LLT.LD_LEG_ID
LEFT JOIN (
	SELECT DISTINCT 
	LOAD_LEG_ID,
	EXTENDED_ATTRIBUTES_TMS:LIVE_LOAD_FLAG AS LIVE_LOAD_FLAG 
	FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_TRANSPORT_TRACKING) TTT
ON LLT.LD_LEG_ID=TTT.LOAD_LEG_ID 
LEFT JOIN TMS.STAGING.CNCY_T C
ON C.CNCY_TYP = LLT.CNCY_TYP
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_CUSTOMER CU
ON CU.CUSTOMER_CODE = LLT.CUST_CD
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SERVICE SE
ON SE.SERVICE_CODE = LLT.SRVC_CD
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_CARRIER CA
ON CA.CARRIER_ID = LLT.CARR_CD
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_DIVISION DI
ON DI.DIVISION_CODE  = LLT.DIV_CD
LEFT JOIN CTE_SHIP_LOC SHF
ON SHF.SHIPPING_LOCATION_CODE = LLT.FRST_SHPG_LOC_CD
LEFT JOIN CTE_SHIP_LOC SHL
ON SHL.SHIPPING_LOCATION_CODE  = LLT.LAST_SHPG_LOC_CD 
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS ADF
ON ADF.ADDRESS_ID = LLT.FRST_ADDR_ID 
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS ADL
ON ADL.ADDRESS_ID = LLT.LAST_ADDR_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_LANE_ASSOCIATION LA
ON LA.LANE_ASSOCIATION_ID = LLT.LANE_ASSC_ID
LEFT JOIN CTE_TRN_STOP ST1
ON ST1.STOP_ID = LLT.FRST_STOP_ID
LEFT JOIN CTE_TRN_STOP ST2
ON ST2.STOP_ID = LLT.LAST_STOP_ID
LEFT JOIN CTE_TRN_STOP ST3
ON ST3.STOP_ID = LLT.FAR_PNT_STOP_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_TARIFF TR1
ON TR1.TARIFF_ID = LLT.TFF_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_TARIFF TR2
ON TR2.TARIFF_ID = LLT.RATE_CD_TFF_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_RATE_CODE RC
ON RC.TARIFF_ID = LLT.TFF_ID AND RC.RATE_CODE = LLT.RATE_CD
LEFT JOIN TMS.STAGING.CNSE_T CN /*Added for service scorecard*/
ON CN.SHPG_LOC_CD = LLT.LAST_SHPG_LOC_CD 
LEFT JOIN TMS.STAGING.LDAT_T DAT  /*Added for service scorecard*/
ON DAT.SHPG_LOC_CD = LLT.FRST_SHPG_LOC_CD 
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_STATUS STAT
ON LLT.CUR_OPTLSTAT_ID = STAT.STATUS_ID /*Added for service scorecard*/
LEFT JOIN SC_LOG.STAGING_TRANSPORT.T_MD_NA_CARRIER MDC 
ON MDC.CARR_CD = LLT.CARR_CD AND MDC.SRVC_CD = LLT.SRVC_CD /*Added for service scorecard*/
LEFT JOIN CTE_AUDT_STOP AUS 
ON AUS.LD_LEG_ID = LLT.LD_LEG_ID /*Added for service scorecard*/
/*WHERE Clause for fetching new/updated records from src table after previous successful load */
WHERE LLT.CC_UPDATED_DATETIMESTAMP > IFNULL( (SELECT DATEADD(hour, -2,CONVERT_TIMEZONE('UTC',LAST_SUCCESSFUL_LOAD_DATETIME)) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2_IMP
WHERE SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2_IMP WHERE SOURCE_NAME='BY_TMS') 
AND TARGET_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT')
AND SOURCE_TABLE_ID =(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.V_TD_GBL_SC_TMS_LOAD_TRANSPORT')) ,'1901-01-01')
);
