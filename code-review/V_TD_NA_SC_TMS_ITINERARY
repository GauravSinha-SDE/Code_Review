create or replace view SC_LOG.INT_TMS.V_TD_NA_SC_TMS_ITINERARY(
	ITINERARY_DELIVERY_SCHEDULE_KEY COMMENT 'Itinerary Delivery Schedule Key',
	DELIVERY_SCHEDULE_CODE COMMENT 'Delivery Schedule Id',
	ITINERARY_CODE COMMENT 'Itinerary ID',
	ITINERARY_DESCRIPTION COMMENT 'Itinerary Description',
	ITINERARY_STATUS_DESCRIPTION COMMENT 'Itinerary Status',
	ITINERARY_TIMETABLE_CODE COMMENT 'Timetable ID',
	ITINERARY_TIMETABLE_DELIVERY_SCHEDULE_CODE COMMENT 'Delivery Schedule ID for Timetable ID (future)',
	CREATED_USER_CODE COMMENT 'Created By User Id',
	UPDATED_USER_CODE COMMENT 'Last Updated By User ID',
	CREATED_DATE_TIME COMMENT 'Created Date/Time',
	UPDATED_DATE_TIME COMMENT 'Last Updated Date/Time',
	ITINERARY_SCHEDULING_METHOD_DESCRIPTION COMMENT 'Itinerary Scheduling Method',
	EXTERNAL_ENGINE_VERSION_ID COMMENT 'Distance Engine ID',
	TRANSIT_MODE_DESCRIPTION COMMENT 'Transit Mode',
	PRIMARY_ITINERARY COMMENT 'Primary Itinerary',
	BUSINESS_HOURS_ID COMMENT 'Business Hours ID',
	WEEKEND_HOLIDAY_SCHEDULING_DESCRIPTION COMMENT 'Weekend / Holiday Scheduling Control',
	TEAM_DRIVER_DESCRIPTION COMMENT 'Team Driver',
	EXTERNAL_SERVICE_TYPE_CODE COMMENT 'External Service Type',
	CC_SOURCE_SYSTEM COMMENT 'Source System',
	CC_TIMEZONE COMMENT 'Time Zone'
) COMMENT='Handy Tools - Itinerary View'
 as
/*To unpivot *_ENU attributes of src table and get their BY_CODE_VALUEs from Domain lkp table */
WITH CTE_ITNRY_LKP
AS
(
SELECT  d.BY_CODE_VALUE, p.*
FROM (   
SELECT
    DLVY_SCHD_CD,
    ITNR_CD,
    DOMAIN_COL_NM,
    CODE_VAL
FROM 
(
Select  ITNR.DLVY_SCHD_CD AS DLVY_SCHD_CD,
        ITNR.ITNR_CD AS ITNR_CD,
        ITNR.STATUS_ENU AS STATUS_ENU,
        ITNR.ITNR_SCHD_MTHD_ENU AS ITNR_SCHD_MTHD_ENU,
        ITNR.TNST_MD_ENU AS TNST_MD_ENU,
        ITNR.WKND_HLDY_SCHD_ENU AS WKND_HLDY_SCHD_ENU,
        ITNR.TEAM_DRVR_ENU AS TEAM_DRVR_ENU
       FROM TMS.STAGING.ITNR_T  ITNR
       WHERE ITNR.AUDIT_UPDATED_TIMESTAMP > COALESCE((SELECT DATEADD(HOUR, -2,LAST_SUCCESSFUL_LOAD_DATETIME) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2_IMP WHERE TARGET_TABLE_ID=(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_ITINERARY')
AND SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2_IMP WHERE SOURCE_NAME='BY_TMS')
AND SOURCE_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_UDM_TMS.V_TD_GBL_SC_TMS_ITINERARY')), '1901-01-01')  
/*WHERE Clause for fetching new/updated domain records from src table after previous successful load */
)
UNPIVOT (
        CODE_VAL FOR DOMAIN_COL_NM IN ( STATUS_ENU,ITNR_SCHD_MTHD_ENU,TNST_MD_ENU,WKND_HLDY_SCHD_ENU,TEAM_DRVR_ENU
        )
      ) 
) p  
LEFT JOIN TMS.STAGING.T_GBL_BY_DOMAIN_LKP d
  ON d.DOMAIN_COLUMN_NAME = p.DOMAIN_COL_NM 
  AND d.BY_CODE = p.CODE_VAL
WHERE CONCAT(DOMAIN_COLUMN_NAME, '|', DOMAIN_TYPE_ID ) IN ('STATUS_ENU|216', 'ITNR_SCHD_MTHD_ENU|523', 
'TNST_MD_ENU|45','WKND_HLDY_SCHD_ENU|452','TEAM_DRVR_ENU|384')
),
/*To aggregate BY_CODE_VALUEs and fetch not null code value corresponding to their domain name.*/
CTE_ITNR_DOMAIN_VAL 
AS(
Select DLVY_SCHD_CD,
       ITNR_CD,
	MAX(CASE WHEN DOMAIN_COL_NM ='STATUS_ENU' THEN BY_CODE_VALUE END) AS ITINERARY_STATUS_DESCRIPTION,
    MAX(CASE WHEN DOMAIN_COL_NM ='ITNR_SCHD_MTHD_ENU' THEN BY_CODE_VALUE END) AS ITINERARY_SCHEDULING_METHOD_DESCRIPTION,
    MAX(CASE WHEN DOMAIN_COL_NM ='TNST_MD_ENU' THEN BY_CODE_VALUE END) AS TRANSIT_MODE_DESCRIPTION,
    MAX(CASE WHEN DOMAIN_COL_NM ='WKND_HLDY_SCHD_ENU' THEN BY_CODE_VALUE END) AS WEEKEND_HOLIDAY_SCHEDULING_DESCRIPTION,
    MAX(CASE WHEN DOMAIN_COL_NM ='TEAM_DRVR_ENU' THEN BY_CODE_VALUE END) AS TEAM_DRIVER_DESCRIPTION
FROM CTE_ITNRY_LKP
GROUP BY DLVY_SCHD_CD,ITNR_CD
)
SELECT
HASH(ITNR.ITNR_CD,ITNR.DLVY_SCHD_CD,'BY') AS ITINERARY_DELIVERY_SCHEDULE_KEY,
ITNR.DLVY_SCHD_CD AS DELIVERY_SCHEDULE_CODE,
ITNR.ITNR_CD AS ITINERARY_CODE,
ITNR.ITNR_DESC AS ITINERARY_DESCRIPTION,
DM.ITINERARY_STATUS_DESCRIPTION AS ITINERARY_STATUS_DESCRIPTION,
ITNR.ITNR_TMTBL_CD AS ITINERARY_TIMETABLE_CODE,
ITNR.ITNR_TMTBL_DS_CD AS ITINERARY_TIMETABLE_DELIVERY_SCHEDULE_CODE,
ITNR.CRTD_USR_CD AS CREATED_USER_CODE,
ITNR.UPDT_USR_CD AS UPDATED_USER_CODE,
ITNR.CRTD_DTT AS CREATED_DATE_TIME,
ITNR.UPDT_DTT AS UPDATED_DATE_TIME,
DM.ITINERARY_SCHEDULING_METHOD_DESCRIPTION AS ITINERARY_SCHEDULING_METHOD_DESCRIPTION,
ITNR.EXTL_EGIN_VER_CD AS EXTERNAL_ENGINE_VERSION_ID,
DM.TRANSIT_MODE_DESCRIPTION AS TRANSIT_MODE_DESCRIPTION,
ITNR.PMY_YN AS PRIMARY_ITINERARY,
ITNR.BUS_HRS_OFST_ID AS BUSINESS_HOURS_ID,
DM.WEEKEND_HOLIDAY_SCHEDULING_DESCRIPTION AS WEEKEND_HOLIDAY_SCHEDULING_DESCRIPTION,
DM.TEAM_DRIVER_DESCRIPTION AS TEAM_DRIVER_DESCRIPTION,
ITNR.EXTL_SRVC_TYP_CD AS EXTERNAL_SERVICE_TYPE_CODE,
'BY' AS CC_SOURCE_SYSTEM,
'UTC' AS CC_TIMEZONE
FROM TMS.STAGING.ITNR_T  ITNR
JOIN CTE_ITNR_DOMAIN_VAL DM
ON ITNR.ITNR_CD = DM.ITNR_CD AND ITNR.DLVY_SCHD_CD = DM.DLVY_SCHD_CD
WHERE ITNR.DLVY_SCHD_CD LIKE '%-IM' /*To filter data for Delivery scheduled code '%-IM'*/
/*Below code for incremantal data load*/
AND ITNR.AUDIT_UPDATED_TIMESTAMP > COALESCE((SELECT DATEADD(HOUR, -2,LAST_SUCCESSFUL_LOAD_DATETIME) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2_IMP WHERE TARGET_TABLE_ID=(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_TMS.T_TD_GBL_SC_TMS_ITINERARY')
AND SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2_IMP WHERE SOURCE_NAME='BY_TMS')
AND SOURCE_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2_IMP WHERE TABLE_NAME='SC_LOG.INT_TMS.V_TD_NA_SC_TMS_ITINERARY')), '1901-01-01');
