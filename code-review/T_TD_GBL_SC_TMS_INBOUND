	LAST_SHIPPING_LOCATION_CODE VARCHAR(100) COMMENT 'The Shipping Location Code For The Final Delivery Stop For The Load; Will Contain A Value When Stops Exist For The Load',
	SHIPPING_LOCATION_NAME VARCHAR(100) COMMENT 'Shipping Location Name',
	DESTINATION_ADDRESS_KEY NUMBER(38,0) COMMENT 'The Address Key For The Last Stop For The Road.',
	LAST_CITY_NAME VARCHAR(100) COMMENT 'Last City Name',
	LAST_STATE_CODE VARCHAR(100) COMMENT 'Last State Code',
	LAST_POSTAL_CODE VARCHAR(100) COMMENT 'Last Postal Code',
	CUSTOMER_HIERARCHY VARCHAR(100) COMMENT 'Customer Hierarchy',
	TRAILER_EQUIPMENT_TYPE VARCHAR(20) COMMENT 'Trailer Equipment Type',
	MAX_VOLUME NUMBER(11,4) COMMENT 'Max Volume',
	NUMBER_OF_STOP_TOTAL NUMBER(38,0) COMMENT 'Number Of Total Stop',
	LAST_COUNTRY_CODE VARCHAR(100) COMMENT 'Last Country Code',
	TOT_SCLD_WGT NUMBER(11,4) COMMENT 'Total Scheduled Weight',
	START_DATE_TIME TIMESTAMP_NTZ(9) COMMENT 'Start Date Time',
	WEEK_NUM NUMBER(38,0) COMMENT 'Week Number',
	DAY_OF_WEEK VARCHAR(3) COMMENT 'Day Of Week',
	END_DOW VARCHAR(3) COMMENT 'End Dow',
	CC_SOURCE_SYSTEM VARCHAR(50) COMMENT 'Source System',
	CC_TIMEZONE VARCHAR(3) COMMENT 'Time Zone',
	AUDIT_UPDATED_TIMESTAMP TIMESTAMP_TZ(9) COMMENT 'Record Updated Date',
	AUDIT_INSERTED_TIMESTAMP TIMESTAMP_TZ(9) COMMENT 'Record Inserted Date',
	LANE VARCHAR(100) COMMENT 'Concat Of Origin Zone Code and Destination Zone Code',
	ACTUAL_CHARGE_AMOUNT NUMBER(15,2) COMMENT 'Actual Charge Amount',
	ACTUAL_LINEHAUL NUMBER(15,2) COMMENT 'Actual Linehaul',
	primary key (LOAD_LEG_KEY)
)COMMENT='Handy Tools- Inbound Table'
;
