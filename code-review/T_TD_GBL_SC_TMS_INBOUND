create or replace TABLE SC_LOG.INT_TMS.T_TD_GBL_SC_TMS_INBOUND (
	LOAD_LEG_KEY NUMBER(38,0) NOT NULL COMMENT 'Identifier For Load Leg Key',
	LOAD_LEG_ID NUMBER(38,0) COMMENT 'Identifier For The Load Leg Id',
	CURRENT_OPERATIONAL_STATUS_ID NUMBER(38,0) COMMENT 'Current Operational Status Id',
	STATUS_SHORT_DESCRIPTION VARCHAR(100) COMMENT 'Status Short Description',
	ORIGIN_SHIPPING_LOCATION_KEY NUMBER(38,0) COMMENT 'The Shipping Location Id For The First Pickup Stop For The Load.',
	FIRST_SHIPPING_LOCATION_CODE VARCHAR(100) COMMENT 'The Shipping Location Code For The First Pickup Stop For The Load; Will Contain A Value When Stops Exist For The Load',
	ORIGIN_ADDRESS_KEY NUMBER(38,0) COMMENT 'The Address Key For The First Pickup Stop For The Load; Will Contain E Value When Stops Exist For The Load',
	FIRST_CITY_NAME VARCHAR(100) COMMENT 'First City Name',
	FIRST_STATE_CODE VARCHAR(50) COMMENT 'First State Code',
